<!-- FILE VIDEO.MP4 PHẢI ĐỂ CÙNG THƯ MỤC VỚI INDEX.HTML -->
<video autoplay muted loop playsinline id="bg-video">
    <source src="video.mp4" type="video/mp4">
</video>
<style>
#bg-video{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
}
</style>
